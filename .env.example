# ---- Public site URL (SEO / canonical) ----
NUXT_PUBLIC_SITE_URL=https://fics.uz

# ---- Image host ----
# img() helper rasmlarni shu manzildan oladi: ${NUXT_PUBLIC_IMAGE_BASE_URL}/images/...
# Agar bo'sh bo'lsa NUXT_PUBLIC_SITE_URL ishlatiladi.
NUXT_PUBLIC_IMAGE_BASE_URL=https://fics.uz

# ---- Backend API ----
NUXT_API_BASE_URL=https://fics.uz/api/api/v1
NUXT_API_BASE_URL_ASSETS=https://fics.uz/api/

# ---- Document upload endpoint (Telegram bot proxy) ----
# NUXT_DOCUMENT_UPLOAD_URL=

# ---- Local dev port ----
PORT=4048
